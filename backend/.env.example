# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── VirusTotal ────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Malice Docker AV (optional) ──────────────────────────────
# Comma-separated list of engines to run (leave empty = all engines)
# Available: clamav,windows-defender,bitdefender,mcafee,fprot,escan,comodo,avira,avg,avast,kaspersky,zoner
MALICE_ENGINES=clamav,windows-defender

# Seconds to wait per container before killing it (default: 120)
MALICE_CONTAINER_TIMEOUT=120

# Temp directory Docker can mount — on Windows must be under a shared drive
# e.g. C:\Users\<you>\AppData\Local\Temp  OR just leave empty to use system temp
MALICE_TMP_DIR=
